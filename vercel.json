{
  "version": 2,
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter property-dashboard run build",
  "outputDirectory": "artifacts/property-dashboard/dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
