{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/property-dashboard run build",
  "outputDirectory": "artifacts/property-dashboard/dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/dist/handler.cjs"
    },
    "api/test.ts": {
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [
    { "source": "/api/diag", "destination": "/api/test" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
